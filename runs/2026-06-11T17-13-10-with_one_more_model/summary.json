    },
    "prompt": {
      "system": "You judge ONE reply from a Hinglish roleplay bot for ENGLISH LEAKAGE. The bot must\nanswer in casual Hinglish (everyday Hindi in Roman script, freely mixing common English\nnouns). Both narration (text inside *asterisks*) and spoken dialogue must obey this.\n\nJudge by GRAMMATICAL FRAME, not script or word count. Hinglish uses Latin letters and is\nfull of English nouns, so English words alone prove nothing.\n- Hindi frame = OK (hai, hoga, karna, kar dein, aapko, uske baad...). English nouns/verbs\n  embedded in a Hindi frame are normal Hinglish.\n- English frame = LEAK (is/are/will/you'll/need to/let me + English word order), in EITHER\n  dialogue or *narration*. One complete English-framed sentence is enough.\n- NOT a leak: embedded English nouns/borrowings (account, settings, office); proper nouns,\n  numbers, URLs, OTP; emojis; pure Devanagari Hindi; fixed interjections/greetings/\n  endearments (thank you, good night, bye, ok, please, sorry, my love).\n\nExamples:\n- \"Aapko account verify karna hoga, uske baad OTP aayega.\"            -> score 0 (clean)\n- \"*She follows you inside, locking the door.* Tum theek ho?\"          -> score 1 (English narration)\n- \"Theek hai. Let me check this and get back to you. Aap wait karein.\" -> score 1 (English sentence)\n\nOutput ONLY this JSON: {\"score\": 1} if the reply LEAKED into English, {\"score\": 0} if it\nstayed Hinglish. No prose, no markdown.\n",
      "user_template": "Bot reply to judge:\n\n{bot_reply}\n\nRespond with ONLY: {\"score\": 0} for clean Hinglish, {\"score\": 1} for an English leak.\n"
    },
    "response_format": {
      "type": "json_schema",
      "json_schema": {
        "name": "english_leak_score",
        "strict": true,
        "schema": {
          "type": "object",
          "required": [
            "score"
          ],
          "additionalProperties": false,
          "properties": {
            "score": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        }
      }
    },
    "verdict": {
      "extract_path": "score",
      "normalize": {
        "0": "PASS",
        "1": "FAIL"
      }
    },
